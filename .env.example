# ----------------------------------------------------------------------------
# Lens IQS — environment variables
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local`.
# ----------------------------------------------------------------------------

# Anthropic Claude API key. Read ONLY by the Edge Function at /api/score.
# Never prefix with NEXT_PUBLIC_ — that would expose it to the client bundle.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model to use for scoring. Sonnet is the default for the demo.
# Override per-deploy via Vercel project env if needed.
LENS_MODEL=claude-sonnet-4-6

# Optional: max input length (chars). Articles longer than this are truncated
# server-side before being sent to Claude.
LENS_MAX_INPUT_CHARS=24000

# Optional: timeout for the Claude call, in ms.
LENS_REQUEST_TIMEOUT_MS=45000
